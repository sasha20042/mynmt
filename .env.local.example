# Supabase (обов'язково для деплою на Render)
# Отримай значення в Dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Бакет для фото до питань (створи в Storage, назва: question-images)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=question-images
