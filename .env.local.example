# --- Airtable (питання, результати, фото) ---
# Токен: https://airtable.com/create/tokens
AIRTABLE_API_KEY=your-personal-access-token
# Base ID — з URL бази: https://airtable.com/appXXXXXXXXXX/... (частина appXXXXXXXXXX)
AIRTABLE_BASE_ID=appXXXXXXXXXX
NEXT_PUBLIC_USE_AIRTABLE=true
# Таблиця для зберігання зображень (поля: Content — Long text, Type — Single line). За замовчуванням ImageStorage
# AIRTABLE_IMAGE_STORAGE_TABLE=ImageStorage

